{
  "schema": "kicadai.schematic.ir.v1",
  "version": 1,
  "metadata": {
    "name": "usb_c_led_indicator",
    "title": "USB-C Powered LED Indicator",
    "description": "USB-C sink CC resistors and a current-limited power LED.",
    "paper": "A4"
  },
  "circuit": {
    "components": [
      {
        "id": "usb_c",
        "ref": "J1",
        "role": "input_connector",
        "symbol": "kicadai:usb_c_receptacle_poweronly_full",
        "footprint": "Connector_USB:USB_C_Receptacle_HRO_TYPE-C-31-M-12",
        "pins": [
          {"number": "A4", "name": "VBUS"},
          {"number": "A9", "name": "VBUS"},
          {"number": "B4", "name": "VBUS"},
          {"number": "B9", "name": "VBUS"},
          {"number": "A1", "name": "GND"},
          {"number": "A12", "name": "GND"},
          {"number": "B1", "name": "GND"},
          {"number": "B12", "name": "GND"},
          {"number": "A5", "name": "CC1"},
          {"number": "B5", "name": "CC2"},
          {"number": "SH", "name": "SHIELD"}
        ]
      },
      {
        "id": "cc1_rd",
        "ref": "R1",
        "role": "resistor",
        "symbol": "Device:R",
        "value": "5.1k",
        "footprint": "Resistor_SMD:R_0603_1608Metric",
        "pins": [{"number": "1"}, {"number": "2"}]
      },
      {
        "id": "cc2_rd",
        "ref": "R2",
        "role": "resistor",
        "symbol": "Device:R",
        "value": "5.1k",
        "footprint": "Resistor_SMD:R_0603_1608Metric",
        "pins": [{"number": "1"}, {"number": "2"}]
      },
      {
        "id": "led_resistor",
        "ref": "R3",
        "role": "current_limiter",
        "symbol": "Device:R",
        "value": "1k",
        "footprint": "Resistor_SMD:R_0805_2012Metric",
        "pins": [{"number": "1"}, {"number": "2"}]
      },
      {
        "id": "power_led",
        "ref": "D1",
        "role": "indicator_led",
        "symbol": "Device:LED",
        "value": "PWR",
        "footprint": "LED_SMD:LED_0805_2012Metric",
        "pins": [{"number": "1"}, {"number": "2"}]
      }
    ],
    "nets": [
      {"name": "VBUS", "role": "power", "connect": ["usb_c.A4", "usb_c.A9", "usb_c.B4", "usb_c.B9", "led_resistor.1"], "label": "VBUS"},
      {"name": "LED_A", "role": "signal", "connect": ["led_resistor.2", "power_led.1"], "label": "LED_A"},
      {"name": "GND", "role": "ground", "connect": ["cc1_rd.2", "usb_c.A1", "usb_c.A12", "usb_c.B1", "usb_c.B12", "usb_c.SH", "power_led.2", "cc2_rd.2"], "label": "GND"},
      {"name": "CC1", "role": "signal", "connect": ["usb_c.A5", "cc1_rd.1"], "label": "CC1"},
      {"name": "CC2", "role": "signal", "connect": ["usb_c.B5", "cc2_rd.1"], "label": "CC2"}
    ]
  },
  "layout": {
    "flow": "left_to_right",
    "origin": "centered",
    "groups": [
      {"id": "indicator", "label": "Indicator", "role": "output_stage", "members": ["power_led"], "rank": 3, "side": "right"}
    ],
    "placements": [
      {"target": "cc1_rd", "orientation": "normal"},
      {"target": "cc2_rd", "orientation": "normal"},
      {"target": "led_resistor", "orientation": "rotated"},
      {"target": "power_led", "group": "indicator", "orientation": "rotated"}
    ],
    "lanes": {"power": "top", "ground": "bottom", "signals": "middle"},
    "rules": {
      "positive_power_top": true,
      "ground_bottom": true,
      "center_on_page": true,
      "prefer_labels_for_long_nets": true,
      "avoid_wire_crossings": true,
      "min_group_spacing_mm": 22,
      "min_component_spacing_mm": 9
    }
  },
  "policy": {
    "repair": {
      "allow_ref_assignment": true,
      "allow_label_insertion": true,
      "allow_group_spacing_adjustment": true,
      "allow_symbol_substitution": false,
      "allow_pin_guessing": false
    },
    "acceptance": "readable"
  }
}
