{
  "version": "0.1.0",
  "name": "sensor_bmp280_breakout",
  "intent": {
    "summary": "USB-powered BMP280 pressure and temperature sensor breakout with a verified concrete sensor topology.",
    "category": "breakout"
  },
  "schematic_layout": {
    "flow": "left_to_right",
    "origin": "centered",
    "groups": [
      {
        "id": "usb_input",
        "label": "USB-C input",
        "role": "input_stage",
        "members": [
          "usb_power__usb_c_receptacle",
          "usb_power__cc1_rd",
          "usb_power__cc2_rd"
        ],
        "rank": 0,
        "side": "left"
      },
      {
        "id": "regulator_input",
        "label": "Regulator input bypass",
        "role": "power_stage",
        "members": ["regulator__input_capacitor"],
        "rank": 1,
        "side": "top"
      },
      {
        "id": "regulator_stage",
        "label": "3.3 V regulator",
        "role": "regulator_stage",
        "members": ["regulator__regulator"],
        "rank": 2
      },
      {
        "id": "regulator_output",
        "label": "Regulator output bypass",
        "role": "decoupling_stage",
        "members": ["regulator__output_capacitor"],
        "rank": 3,
        "side": "top"
      },
      {
        "id": "sensor_support",
        "label": "Sensor support",
        "role": "decoupling_stage",
        "members": [
          "sensor__decoupling_capacitor",
          "sensor__sda_pullup",
          "sensor__scl_pullup"
        ],
        "rank": 4,
        "side": "top"
      },
      {
        "id": "sensor_stage",
        "label": "BMP280 sensor",
        "role": "processing_stage",
        "members": ["sensor__sensor"],
        "rank": 5
      },
      {
        "id": "i2c_output",
        "label": "I2C connector",
        "role": "output_stage",
        "members": ["i2c_connector__connector"],
        "rank": 6,
        "side": "right"
      }
    ],
    "lanes": {
      "power": "top",
      "ground": "bottom",
      "signals": "middle"
    },
    "rules": {
      "positive_power_top": true,
      "ground_bottom": true,
      "center_on_page": true,
      "prefer_labels_for_long_nets": true,
      "avoid_wire_crossings": true,
      "min_group_spacing_mm": 30.48,
      "min_component_spacing_mm": 12.7
    },
    "placements": [
      {
        "target": "usb_power__usb_c_receptacle",
        "group": "usb_input"
      },
      {
        "target": "usb_power__cc1_rd",
        "group": "usb_input",
        "near": ["usb_power__usb_c_receptacle"]
      },
      {
        "target": "usb_power__cc2_rd",
        "group": "usb_input",
        "near": ["usb_power__usb_c_receptacle"]
      },
      {
        "target": "regulator__input_capacitor",
        "group": "regulator_input",
        "near": ["regulator__regulator"],
        "above": ["regulator__regulator"],
        "right_of": ["usb_power__usb_c_receptacle"]
      },
      {
        "target": "regulator__regulator",
        "group": "regulator_stage",
        "right_of": ["usb_power__usb_c_receptacle"]
      },
      {
        "target": "regulator__output_capacitor",
        "group": "regulator_output",
        "near": ["regulator__regulator"],
        "above": ["regulator__regulator"],
        "right_of": ["regulator__regulator"]
      },
      {
        "target": "sensor__decoupling_capacitor",
        "group": "sensor_support",
        "near": ["sensor__sensor"],
        "above": ["sensor__sensor"],
        "right_of": ["regulator__regulator"]
      },
      {
        "target": "sensor__sda_pullup",
        "group": "sensor_support",
        "near": ["sensor__sensor"],
        "above": ["sensor__sensor"]
      },
      {
        "target": "sensor__scl_pullup",
        "group": "sensor_support",
        "near": ["sensor__sensor"],
        "above": ["sensor__sensor"]
      },
      {
        "target": "sensor__sensor",
        "group": "sensor_stage",
        "right_of": ["regulator__regulator"]
      },
      {
        "target": "i2c_connector__connector",
        "group": "i2c_output",
        "right_of": ["sensor__sensor"]
      }
    ]
  },
  "board": {
    "width_mm": 40,
    "height_mm": 75,
    "layers": 2,
    "edge_clearance_mm": 0.25
  },
  "libraries": {},
  "component_policy": {
    "minimum_confidence": "library_derived",
    "acceptance": "erc_drc",
    "procurement_policy": {},
    "overrides": {
      "regulator.input_capacitor": {
        "required_ratings": [
          {
            "kind": "voltage",
            "value": "6.3",
            "unit": "V"
          }
        ]
      },
      "regulator.output_capacitor": {
        "required_ratings": [
          {
            "kind": "voltage",
            "value": "6.3",
            "unit": "V"
          }
        ]
      },
      "regulator.regulator": {
        "required_ratings": [
          {
            "kind": "input_voltage",
            "value": "5",
            "unit": "V"
          },
          {
            "kind": "output_current",
            "value": "0.05",
            "unit": "A"
          }
        ]
      }
    }
  },
  "blocks": [
    {
      "id": "usb_power",
      "block_id": "usb_c_power",
      "params": {
        "include_bulk_capacitor": false,
        "include_fuse": false,
        "include_power_led": false,
        "include_tvs": false,
        "shield_policy": "floating"
      }
    },
    {
      "id": "regulator",
      "block_id": "voltage_regulator",
      "params": {
        "enable_mode": "tied_input",
        "input_voltage": "5V",
        "input_voltage_max": "5V",
        "input_voltage_min": "5V",
        "output_current": "0.05A",
        "output_voltage": "3.3V",
        "regulator_footprint": "Package_TO_SOT_SMD:SOT-23-5",
        "regulator_symbol": "Regulator_Linear:AP2112K-3.3"
      }
    },
    {
      "id": "sensor",
      "block_id": "i2c_sensor",
      "params": {
        "i2c_address": "0x76",
        "pullup_value": "4.7k",
        "sensor_component_id": "sensor.bosch.bmp280.lga8",
        "supply_voltage": "3.3V"
      }
    },
    {
      "id": "i2c_connector",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": [
          "VCC",
          "GND",
          "SDA",
          "SCL"
        ]
      }
    }
  ],
  "connections": [
    {
      "from": "usb_power.VBUS_OUT",
      "to": "regulator.VIN",
      "net_alias": "VIN_RAW_usb_power"
    },
    {
      "from": "usb_power.GND",
      "to": "regulator.GND",
      "net_alias": "GND"
    },
    {
      "from": "regulator.VOUT",
      "to": "sensor.VCC",
      "net_alias": "VCC_3v3v"
    },
    {
      "from": "usb_power.GND",
      "to": "i2c_connector.GND",
      "net_alias": "GND"
    },
    {
      "from": "usb_power.GND",
      "to": "sensor.GND",
      "net_alias": "GND"
    },
    {
      "from": "usb_power.GND",
      "to": "regulator.GND",
      "net_alias": "GND"
    },
    {
      "from": "i2c_connector.SDA",
      "to": "sensor.SDA",
      "net_alias": "SDA"
    },
    {
      "from": "i2c_connector.SCL",
      "to": "sensor.SCL",
      "net_alias": "SCL"
    },
    {
      "from": "regulator.VOUT",
      "to": "i2c_connector.VCC",
      "net_alias": "VCC_3v3v"
    }
  ],
  "constraints": {},
  "validation": {
    "acceptance": "erc-drc",
    "require_erc": true,
    "require_drc": true,
    "strict_unrouted": true,
    "strict_zones": true
  },
  "routing_retry": {
    "max_attempts": 1,
    "allowed_hint_categories": [
      "reduce_distance",
      "increase_spacing",
      "improve_fanout",
      "move_from_edge"
    ]
  }
}
