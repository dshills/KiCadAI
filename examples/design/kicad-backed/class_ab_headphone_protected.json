{
  "version": "0.1.0",
  "name": "class_ab_headphone_protected",
  "intent": {
    "summary": "KiCad-backed evidence fixture for the protected Class AB headphone path with op-amp voltage gain, diode-biased complementary output stage, and headphone_output_protection.",
    "category": "amplifier"
  },
  "board": {
    "width_mm": 160,
    "height_mm": 100,
    "layers": 2
  },
  "component_policy": {
    "minimum_confidence": "verified",
    "acceptance": "connectivity"
  },
  "blocks": [
    {
      "id": "input",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": ["SIG", "GND"]
      }
    },
    {
      "id": "gain",
      "block_id": "opamp_gain_stage",
      "params": {
        "topology": "non_inverting",
        "gain": 2,
        "single_supply": true,
        "input_coupling": "ac",
        "include_output_resistor": true
      }
    },
    {
      "id": "output",
      "block_id": "class_ab_output_stage",
      "params": {
        "topology": "diode_string",
        "supply_voltage": "9V",
        "load_impedance": "32Ω"
      }
    },
    {
      "id": "headphones",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": ["SIG", "RET"]
      }
    },
    {
      "id": "output_protection",
      "block_id": "headphone_output_protection",
      "params": {
        "load_kind": "headphone",
        "nominal_load_ohms": "32Ω",
        "dc_blocking_capacitance": "220uF",
        "bleed_resistor_ohms": "100kΩ",
        "connector_return_policy": "load_ref",
        "fault_protection_status": "placeholder_blocked"
      }
    },
    {
      "id": "power",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": ["VCC", "LOAD_REF"]
      }
    }
  ],
  "connections": [
    {"from": "input.SIG", "to": "gain.IN", "net_alias": "AUDIO_IN"},
    {"from": "input.GND", "to": "output.LOAD_REF", "net_alias": "LOAD_REF"},
    {"from": "gain.OUT", "to": "output.DRIVER_OUT", "net_alias": "DRIVER_OUT"},
    {"from": "gain.VCC", "to": "output.VCC", "net_alias": "VCC"},
    {"from": "gain.GND", "to": "output.LOAD_REF", "net_alias": "LOAD_REF"},
    {"from": "output.AMP_OUT", "to": "output_protection.AMP_OUT", "net_alias": "AMP_OUT_DC_BIASED"},
    {"from": "output_protection.HP_OUT", "to": "headphones.SIG", "net_alias": "HP_OUT"},
    {"from": "output.LOAD_REF", "to": "output_protection.LOAD_REF", "net_alias": "LOAD_REF"},
    {"from": "output_protection.LOAD_RET", "to": "headphones.RET", "net_alias": "HP_RET"},
    {"from": "power.VCC", "to": "gain.VCC", "net_alias": "VCC"},
    {"from": "power.VCC", "to": "output.VCC", "net_alias": "VCC"},
    {"from": "power.LOAD_REF", "to": "gain.GND", "net_alias": "LOAD_REF"},
    {"from": "power.LOAD_REF", "to": "output.VEE", "net_alias": "LOAD_REF"},
    {"from": "power.LOAD_REF", "to": "output.LOAD_REF", "net_alias": "LOAD_REF"}
  ],
  "validation": {
    "acceptance": "connectivity",
    "skip_routing": false,
    "skip_kicad_checks": true
  }
}
