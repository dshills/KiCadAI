{
  "version": "0.1.0",
  "name": "amplifier_module",
  "summary": "Small op-amp gain stage with GPIO-style signal connector.",
  "kind": "amplifier",
  "acceptance": "connectivity",
  "board": {
    "width_mm": 50,
    "height_mm": 30,
    "layers": 2
  },
