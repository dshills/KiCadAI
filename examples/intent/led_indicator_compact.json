{
  "version": "0.1.0",
  "name": "led_indicator_compact",
  "summary": "Active-high red 5 V LED indicator with a power header, routed at connectivity acceptance.",
  "kind": "breakout",
  "acceptance": "connectivity",
  "board": {
    "width_mm": 40,
    "height_mm": 25,
    "layers": 2
  },
  "power": {
    "inputs": [
      {
        "kind": "external",
        "voltage": "5V",
        "current_ma": 20
      }
    ]
  },
  "functions": [
    {
      "kind": "indicator",
      "params": {
        "color": "red",
        "supply_voltage": "5V",
        "led_forward_voltage": "2.0V",
        "led_current": "10mA",
        "active_high": true
      }
    }
  ]
}
