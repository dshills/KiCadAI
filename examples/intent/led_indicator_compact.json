{
  "version": "0.1.0",
  "name": "led_indicator_compact",
  "intent": {
    "summary": "Active-high red 5 V LED indicator with a power header, routed at connectivity acceptance.",
    "category": "indicator"
  },
  "board": {
    "width_mm": 40,
    "height_mm": 25,
    "layers": 2
  },
  "blocks": [
    {
      "id": "power",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": [
          "VCC",
          "GND"
        ]
      }
    },
    {
      "id": "status",
      "block_id": "led_indicator",
      "params": {
        "color": "red",
        "supply_voltage": "5V",
        "led_forward_voltage": "2.0V",
        "led_current": "10mA",
        "active_high": true
      }
    }
  ],
  "connections": [
    {
      "from": "power.VCC",
      "to": "status.IN",
      "net_alias": "VCC"
    },
    {
      "from": "power.VCC",
      "to": "status.VCC",
      "net_alias": "VCC"
    },
    {
      "from": "power.GND",
      "to": "status.GND",
      "net_alias": "GND"
    }
  ],
  "validation": {
    "acceptance": "connectivity",
    "skip_routing": false
  }
}
