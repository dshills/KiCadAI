  "functions": [
    {"kind": "mcu", "params": {"supply_voltage": "5V"}},
    {"kind": "mcu", "params": {"supply_voltage": "5V"}},
    {"kind": "reset_programming", "params": {"programming_interface": "isp"}}
  ]
}
