{
  "version": "0.1.0",
  "name": "multi_mcu_ambiguous_support",
  "summary": "Two MCUs with one untargeted programming support block; planner must not guess.",
  "kind": "custom_structured",
  "acceptance": "structural",
  "board": {
    "width_mm": 80,
    "height_mm": 50,
    "layers": 2
  },
