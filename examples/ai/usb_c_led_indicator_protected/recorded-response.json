{
  "schema": "kicadai.ai.intent.v1",
  "intent": {
    "version": "0.1.0",
    "name": "usb_c_led_indicator_protected",
    "kind": "breakout",
    "acceptance": "erc-drc",
    "auto_schematic_layout": true,
    "board": {
      "width_mm": 50,
      "height_mm": 30,
      "layers": 2,
      "mounting_holes": "optional"
    },
    "power": {
      "inputs": [
        {
          "kind": "usb_c",
          "voltage": "5V",
          "current_ma": 100,
          "strength": "required"
        }
      ]
    },
    "functions": [
      {
        "kind": "indicator",
        "family": "led_indicator",
        "quantity": 1,
        "params": {
          "active_high": true,
          "supply_voltage": "5V",
          "led_forward_voltage": "2.0V",
          "led_current_ma": 5
        },
        "strength": "required",
        "supply": "5V"
      }
    ],
    "protection": {
      "esd": "optional",
      "reverse_polarity": "optional",
      "overcurrent": "required",
      "transient": "required",
      "bulk_capacitance": "required"
    }
  }
