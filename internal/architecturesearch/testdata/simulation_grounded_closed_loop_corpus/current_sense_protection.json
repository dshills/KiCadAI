{
  "schema": "kicadai.open-set-requirement.v3", "version": 3,
  "project": {"name": "current_sense_protection", "title": "Current-sensed protected load controller", "description": "Measure load current, disconnect an overloaded output, and indicate the fault without unsafe startup."},
  "requirements": {
    "domains": [{"id": "load_12v", "kind": "supply", "min_voltage_v": 10, "nominal_voltage_v": 12, "max_voltage_v": 14, "max_current_a": 3, "source": "external"}, {"id": "logic_5v", "kind": "supply", "min_voltage_v": 4.75, "nominal_voltage_v": 5, "max_voltage_v": 5.25, "max_current_a": 0.1, "source": "external"}, {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}],
    "ports": [{"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "load_power", "kind": "power", "direction": "sink", "domain": "load_12v"}, {"id": "logic_power", "kind": "power", "direction": "sink", "domain": "logic_5v"}, {"id": "load", "kind": "protected_output", "direction": "source", "domain": "load_12v"}, {"id": "fault", "kind": "digital_logic", "direction": "source", "domain": "logic_5v"}],
    "signals": [{"id": "measured_current", "kind": "analog_voltage", "domain": "ground"}, {"id": "trip", "kind": "digital_logic", "domain": "logic_5v"}],
    "objectives": [{"id": "measure", "capability": "current_sensing", "bindings": [{"role": "power", "port": "load_power"}, {"role": "output", "signal": "measured_current", "direction": "source"}, {"role": "reference", "port": "ground"}]}, {"id": "decide", "capability": "threshold_detection", "bindings": [{"role": "input", "signal": "measured_current", "direction": "sink"}, {"role": "output", "signal": "trip", "direction": "source"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}]}, {"id": "switch", "capability": "load_switch", "bindings": [{"role": "control", "signal": "trip", "direction": "sink"}, {"role": "power", "port": "load_power"}, {"role": "output", "port": "load"}, {"role": "reference", "port": "ground"}]}, {"id": "indicate", "capability": "fault_indication", "bindings": [{"role": "input", "signal": "trip", "direction": "sink"}, {"role": "output", "port": "fault"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}]}],
    "operating_cases": [{"id": "overload", "conditions": [{"axis": "supply_voltage", "target": "load_12v", "min": 10, "max": 14, "unit": "V"}, {"axis": "load_current", "target": "load", "min": 0, "max": 3, "unit": "A"}, {"axis": "ambient_temperature", "target": "circuit", "min": -20, "max": 70, "unit": "degC"}]}],
    "behavioral_requirements": [{"id": "sense_gain", "metric": "transimpedance", "analysis": "dc_operating_point", "observation": {"kind": "signal", "id": "measured_current"}, "min": 0.98, "max": 1.02, "unit": "V/A", "operating_cases": ["overload"]}, {"id": "trip_current", "metric": "threshold_current", "analysis": "dc_operating_point", "observation": {"kind": "signal", "id": "trip"}, "min": 1.9, "max": 2.1, "unit": "A", "operating_cases": ["overload"], "critical": true}, {"id": "response", "metric": "response_time", "analysis": "transient", "observation": {"kind": "port", "id": "load"}, "max": 0.001, "unit": "s", "operating_cases": ["overload"], "critical": true}, {"id": "startup", "metric": "startup_output_voltage", "analysis": "startup", "observation": {"kind": "port", "id": "load"}, "max": 0.5, "unit": "V", "operating_cases": ["overload"], "critical": true}],
    "constraints": {"max_components": 32, "max_width_mm": 75, "max_height_mm": 52}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true, "require_simulation": true, "require_all_corners": true, "require_model_provenance": true, "require_closed_loop_evidence": true}
