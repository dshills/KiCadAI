    "objectives": [{"id": "regulate", "capability": "voltage_regulation", "bindings": [{"role": "input", "port": "power"}, {"role": "output", "signal": "sensor_rail", "direction": "source"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "transient_load_current", "relation": "maximum", "value": 0.15, "unit": "A"}, {"name": "transient_duration", "relation": "maximum", "value": 0.0001, "unit": "s"}, {"name": "maximum_voltage_droop", "relation": "maximum", "value": 0.1, "unit": "V"}]}, {"id": "condition_internal_bus", "capability": "logic_level_translation", "bindings": [{"role": "side_a", "participant": "controller", "participant_port": "sensor_bus"}, {"role": "side_b", "participant": "sensor", "participant_port": "controller_bus"}, {"role": "power_a", "signal": "sensor_rail", "direction": "sink"}, {"role": "power_b", "signal": "sensor_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}]}, {"id": "translate", "capability": "logic_level_translation", "bindings": [{"role": "side_a", "port": "host_bus"}, {"role": "side_b", "signal": "translated_bus", "direction": "source"}, {"role": "power_a", "port": "power"}, {"role": "power_b", "signal": "sensor_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}]}, {"id": "protect", "capability": "transient_protection", "bindings": [{"role": "input", "signal": "translated_bus", "direction": "sink"}, {"role": "output", "port": "sensor_bus"}, {"role": "reference", "port": "ground"}]}],
