  "project": {"name": "regulated_mcu_sensor_subsystem", "title": "Regulated MCU and environmental sensor subsystem", "description": "Generate a 3.3 V rail from a wider input, power a programmable controller and environmental sensor, condition their open-drain bus, and preserve startup and load behavior over supply corners."},
