{
  "schema": "kicadai.open-set-requirement.v3",
  "version": 3,
  "project": {
    "name": "analog_precision_rectifier",
    "title": "Bipolar precision magnitude interface",
    "description": "Convert either polarity of a bounded analog input into a positive magnitude output with low transfer error and bounded settling time."
  },
  "requirements": {
    "domains": [
      {
        "id": "analog_5v",
        "kind": "supply",
        "min_voltage_v": 4.75,
        "nominal_voltage_v": 5,
        "max_voltage_v": 5.25,
        "max_current_a": 0.05,
        "source": "external"
      },
      {
        "id": "ground",
        "kind": "reference",
        "nominal_voltage_v": 0,
        "source": "external"
      }
    ],
    "ports": [
      {
        "id": "ground",
        "kind": "reference",
        "direction": "bidirectional",
        "domain": "ground"
      },
      {
        "id": "power",
        "kind": "power",
        "direction": "sink",
        "domain": "analog_5v",
        "electrical": {
          "max_current_a": 0.05
        }
      },
      {
        "id": "input",
        "kind": "analog_voltage",
        "direction": "sink",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": -1,
          "max_voltage_v": 1,
          "input_impedance_min_ohm": 100000,
          "frequency_max_hz": 1000
        }
      },
      {
        "id": "output",
        "kind": "analog_voltage",
        "direction": "source",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": 0,
          "max_voltage_v": 1.1,
          "max_source_current_ma": 2,
          "frequency_max_hz": 1000
        }
      }
    ],
    "objectives": [
      {
        "id": "convert_magnitude",
        "capability": "precision_rectification",
        "bindings": [
          {
            "role": "input",
            "port": "input"
          },
          {
            "role": "output",
            "port": "output"
          },
          {
            "role": "power",
            "port": "power"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "input_peak",
            "relation": "maximum",
            "value": 1,
            "unit": "V"
          },
          {
            "name": "transfer_error",
            "relation": "maximum",
            "value": 0.05,
            "unit": "V"
          },
          {
            "name": "minimum_input_impedance",
            "relation": "minimum",
            "value": 100000,
            "unit": "Ohm"
          }
        ]
      }
    ],
    "operating_cases": [
      {
        "id": "negative_input",
        "conditions": [
          {
            "axis": "input_amplitude",
            "target": "input",
            "min": -1,
            "max": -1,
            "unit": "V"
          },
          {
            "axis": "supply_voltage",
            "target": "analog_5v",
            "min": 4.75,
            "max": 5.25,
            "unit": "V"
          },
          {
            "axis": "load_resistance",
            "target": "output",
            "min": 10000,
            "max": 100000,
            "unit": "Ohm"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      },
      {
        "id": "positive_input",
        "conditions": [
          {
            "axis": "input_amplitude",
            "target": "input",
            "min": 1,
            "max": 1,
            "unit": "V"
          },
          {
            "axis": "supply_voltage",
            "target": "analog_5v",
            "min": 4.75,
            "max": 5.25,
            "unit": "V"
          },
          {
            "axis": "load_resistance",
            "target": "output",
            "min": 10000,
            "max": 100000,
            "unit": "Ohm"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      }
    ],
    "behavioral_requirements": [
      {
        "id": "negative_transfer",
        "metric": "dc_voltage",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "output"
        },
        "min": 0.95,
        "max": 1.05,
        "unit": "V",
        "operating_cases": [
          "negative_input"
        ],
        "critical": true
      },
      {
        "id": "positive_transfer",
        "metric": "dc_voltage",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "output"
        },
        "min": 0.95,
        "max": 1.05,
        "unit": "V",
        "operating_cases": [
          "positive_input"
        ],
        "critical": true
      },
      {
        "id": "settling",
        "metric": "settling_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "output"
        },
        "max": 0.001,
        "unit": "s",
        "operating_cases": [
          "negative_input",
          "positive_input"
        ]
      },
      {
        "id": "supply_current",
        "metric": "quiescent_current",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "circuit",
          "id": "circuit"
        },
        "max": 0.01,
        "unit": "A",
        "operating_cases": [
          "negative_input",
          "positive_input"
        ]
      }
    ],
    "constraints": {
      "max_components": 18,
      "max_width_mm": 45,
      "max_height_mm": 32
    }
  },
  "acceptance": {
    "require_erc": true,
    "require_strict_drc": true,
    "require_complete_routing": true,
    "require_connectivity": true,
    "require_writer_correctness": true,
    "require_round_trip_zero_diff": true,
    "require_deterministic_replay": true,
    "require_contract_composition": true,
    "require_global_reasoning": true,
    "require_coverage_accounting": true,
    "require_alternatives": true,
    "require_fail_closed": true,
    "require_simulation": true,
    "require_all_corners": true,
    "require_model_provenance": true,
    "require_closed_loop_evidence": true
  }
}
