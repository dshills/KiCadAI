{
  "schema": "kicadai.open-set-requirement.v3",
  "version": 3,
  "project": {
    "name": "power_constant_current_output",
    "title": "Bounded constant-current power output",
    "description": "Provide a protected current-regulated output over a declared supply and load range with safe startup and thermal margin."
  },
  "requirements": {
    "domains": [
      {
        "id": "input_12v",
        "kind": "supply",
        "min_voltage_v": 10.8,
        "nominal_voltage_v": 12,
        "max_voltage_v": 13.2,
        "max_current_a": 0.2,
        "source": "external"
      },
      {
        "id": "ground",
        "kind": "reference",
        "nominal_voltage_v": 0,
        "source": "external"
      }
    ],
    "ports": [
      {
        "id": "ground",
        "kind": "reference",
        "direction": "bidirectional",
        "domain": "ground"
      },
      {
        "id": "power",
        "kind": "power",
        "direction": "sink",
        "domain": "input_12v",
        "electrical": {
          "max_current_a": 0.2
        }
      },
      {
        "id": "current_output",
        "kind": "protected_output",
        "direction": "source",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": 0,
          "max_voltage_v": 8,
          "max_source_current_ma": 22
        }
      }
    ],
    "objectives": [
      {
        "id": "regulate_current",
        "capability": "constant_current_regulation",
        "bindings": [
          {
            "role": "input",
            "port": "power"
          },
          {
            "role": "output",
            "port": "current_output"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "output_current",
            "relation": "target",
            "value": 0.02,
            "unit": "A",
            "tolerance_percent": 5
          },
          {
            "name": "minimum_compliance_voltage",
            "relation": "minimum",
            "value": 8,
            "unit": "V"
          },
          {
            "name": "default_off",
            "relation": "required",
            "value": true
          }
        ]
      }
    ],
    "operating_cases": [
      {
        "id": "rated_load",
        "conditions": [
          {
            "axis": "supply_voltage",
            "target": "input_12v",
            "min": 10.8,
            "max": 13.2,
            "unit": "V"
          },
          {
            "axis": "load_resistance",
            "target": "current_output",
            "min": 50,
            "max": 400,
            "unit": "Ohm"
          },
          {
            "axis": "ambient_temperature",
            "target": "circuit",
            "min": -20,
            "max": 70,
            "unit": "degC"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      }
    ],
    "behavioral_requirements": [
      {
        "id": "regulated_current",
        "metric": "dc_current",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "current_output"
        },
        "min": 0.019,
        "max": 0.021,
        "unit": "A",
        "operating_cases": [
          "rated_load"
        ],
        "critical": true
      },
      {
        "id": "response",
        "metric": "response_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "current_output"
        },
        "max": 0.001,
        "unit": "s",
        "operating_cases": [
          "rated_load"
        ]
      },
      {
        "id": "startup",
        "metric": "startup_output_voltage",
        "analysis": "startup",
        "observation": {
          "kind": "port",
          "id": "current_output"
        },
        "max": 1,
        "unit": "V",
        "operating_cases": [
          "rated_load"
        ],
        "critical": true
      },
      {
        "id": "thermal",
        "metric": "junction_temperature",
        "analysis": "thermal",
        "observation": {
          "kind": "port",
          "id": "current_output"
        },
        "max": 125,
        "unit": "degC",
        "operating_cases": [
          "rated_load"
        ],
        "critical": true
      }
    ],
    "constraints": {
      "max_components": 14,
      "max_width_mm": 48,
      "max_height_mm": 34
    }
  },
  "acceptance": {
    "require_erc": true,
    "require_strict_drc": true,
    "require_complete_routing": true,
    "require_connectivity": true,
    "require_writer_correctness": true,
    "require_round_trip_zero_diff": true,
    "require_deterministic_replay": true,
    "require_contract_composition": true,
    "require_global_reasoning": true,
    "require_coverage_accounting": true,
    "require_alternatives": true,
    "require_fail_closed": true,
    "require_simulation": true,
    "require_all_corners": true,
    "require_model_provenance": true,
    "require_closed_loop_evidence": true
  }
}
