{
  "schema": "kicadai.open-set-requirement.v3",
  "version": 3,
  "project": {
    "name": "mixed_signal_rectified_acquisition",
    "title": "Rectified analog acquisition interface",
    "description": "Convert a bipolar sensor signal to its positive magnitude and settle it into a bounded data-converter acquisition load."
  },
  "requirements": {
    "domains": [
      {
        "id": "analog_5v",
        "kind": "supply",
        "min_voltage_v": 4.75,
        "nominal_voltage_v": 5,
        "max_voltage_v": 5.25,
        "max_current_a": 0.1,
        "source": "external"
      },
      {
        "id": "ground",
        "kind": "reference",
        "nominal_voltage_v": 0,
        "source": "external"
      }
    ],
    "ports": [
      {
        "id": "ground",
        "kind": "reference",
        "direction": "bidirectional",
        "domain": "ground"
      },
      {
        "id": "power",
        "kind": "power",
        "direction": "sink",
        "domain": "analog_5v",
        "electrical": {
          "max_current_a": 0.1
        }
      },
      {
        "id": "sensor_input",
        "kind": "analog_voltage",
        "direction": "sink",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": -1,
          "max_voltage_v": 1,
          "input_impedance_min_ohm": 100000,
          "frequency_max_hz": 2000
        }
      },
      {
        "id": "converter_input",
        "kind": "analog_voltage",
        "direction": "source",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": 0,
          "max_voltage_v": 1.1,
          "max_source_current_ma": 2,
          "frequency_max_hz": 2000
        }
      }
    ],
    "signals": [
      {
        "id": "magnitude",
        "kind": "analog_voltage",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": 0,
          "max_voltage_v": 1.1,
          "frequency_max_hz": 2000
        }
      }
    ],
    "objectives": [
      {
        "id": "convert_magnitude",
        "capability": "precision_rectification",
        "bindings": [
          {
            "role": "input",
            "port": "sensor_input"
          },
          {
            "role": "output",
            "signal": "magnitude",
            "direction": "source"
          },
          {
            "role": "power",
            "port": "power"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "input_peak",
            "relation": "maximum",
            "value": 1,
            "unit": "V"
          },
          {
            "name": "transfer_error",
            "relation": "maximum",
            "value": 0.05,
            "unit": "V"
          }
        ]
      },
      {
        "id": "condition_converter",
        "capability": "adc_drive_conditioning",
        "bindings": [
          {
            "role": "input",
            "signal": "magnitude",
            "direction": "sink"
          },
          {
            "role": "output",
            "port": "converter_input"
          },
          {
            "role": "power",
            "port": "power"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "source_impedance",
            "relation": "maximum",
            "value": 10000,
            "unit": "Ohm"
          },
          {
            "name": "adc_input_capacitance",
            "relation": "target",
            "value": 0.00000000002,
            "unit": "F"
          },
          {
            "name": "acquisition_time",
            "relation": "minimum",
            "value": 0.000002,
            "unit": "s"
          },
          {
            "name": "settling_accuracy",
            "relation": "maximum",
            "value": 0.0005,
            "unit": "ratio"
          },
          {
            "name": "maximum_input_step",
            "relation": "maximum",
            "value": 1.1,
            "unit": "V"
          }
        ]
      }
    ],
    "operating_cases": [
      {
        "id": "negative_input",
        "conditions": [
          {
            "axis": "input_amplitude",
            "target": "sensor_input",
            "min": -1,
            "max": -1,
            "unit": "V"
          },
          {
            "axis": "supply_voltage",
            "target": "analog_5v",
            "min": 4.75,
            "max": 5.25,
            "unit": "V"
          },
          {
            "axis": "load_capacitance",
            "target": "converter_input",
            "min": 0.000000000005,
            "max": 0.00000000002,
            "unit": "F"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      },
      {
        "id": "positive_input",
        "conditions": [
          {
            "axis": "input_amplitude",
            "target": "sensor_input",
            "min": 1,
            "max": 1,
            "unit": "V"
          },
          {
            "axis": "supply_voltage",
            "target": "analog_5v",
            "min": 4.75,
            "max": 5.25,
            "unit": "V"
          },
          {
            "axis": "load_capacitance",
            "target": "converter_input",
            "min": 0.000000000005,
            "max": 0.00000000002,
            "unit": "F"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      }
    ],
    "behavioral_requirements": [
      {
        "id": "negative_transfer",
        "metric": "dc_voltage",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "converter_input"
        },
        "min": 0.95,
        "max": 1.05,
        "unit": "V",
        "operating_cases": [
          "negative_input"
        ],
        "critical": true
      },
      {
        "id": "positive_transfer",
        "metric": "dc_voltage",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "converter_input"
        },
        "min": 0.95,
        "max": 1.05,
        "unit": "V",
        "operating_cases": [
          "positive_input"
        ],
        "critical": true
      },
      {
        "id": "settling",
        "metric": "settling_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "converter_input"
        },
        "max": 0.00001,
        "unit": "s",
        "operating_cases": [
          "negative_input",
          "positive_input"
        ]
      },
      {
        "id": "noise",
        "metric": "integrated_output_noise",
        "analysis": "noise",
        "observation": {
          "kind": "port",
          "id": "converter_input"
        },
        "max": 0.0002,
        "unit": "V_rms",
        "operating_cases": [
          "negative_input",
          "positive_input"
        ]
      }
    ],
    "constraints": {
      "max_components": 24,
      "max_width_mm": 56,
      "max_height_mm": 38
    }
  },
  "acceptance": {
    "require_erc": true,
    "require_strict_drc": true,
    "require_complete_routing": true,
    "require_connectivity": true,
    "require_writer_correctness": true,
    "require_round_trip_zero_diff": true,
    "require_deterministic_replay": true,
    "require_contract_composition": true,
    "require_global_reasoning": true,
    "require_coverage_accounting": true,
    "require_alternatives": true,
    "require_fail_closed": true,
    "require_simulation": true,
    "require_all_corners": true,
    "require_model_provenance": true,
    "require_closed_loop_evidence": true
  }
}
