{
  "schema": "kicadai.open-set-requirement.v3",
  "version": 3,
  "project": {
    "name": "digital_clock_source",
    "title": "Bounded digital clock source",
    "description": "Generate a single-ended logic clock with bounded frequency, edge rate, startup time, fanout, and output levels."
  },
  "requirements": {
    "domains": [
      {
        "id": "logic_3v3",
        "kind": "supply",
        "min_voltage_v": 3.15,
        "nominal_voltage_v": 3.3,
        "max_voltage_v": 3.45,
        "max_current_a": 0.1,
        "source": "external"
      },
      {
        "id": "ground",
        "kind": "reference",
        "nominal_voltage_v": 0,
        "source": "external"
      }
    ],
    "ports": [
      {
        "id": "ground",
        "kind": "reference",
        "direction": "bidirectional",
        "domain": "ground"
      },
      {
        "id": "power",
        "kind": "power",
        "direction": "sink",
        "domain": "logic_3v3",
        "electrical": {
          "max_current_a": 0.1
        }
      },
      {
        "id": "clock",
        "kind": "digital_logic",
        "direction": "source",
        "domain": "logic_3v3",
        "electrical": {
          "min_voltage_v": 0,
          "max_voltage_v": 3.3,
          "max_source_current_ma": 8,
          "frequency_max_hz": 8000000,
          "default_state": "inactive"
        },
        "protocol": {
          "name": "clock",
          "mode": "single_ended",
          "max_frequency_hz": 8000000
        }
      }
    ],
    "objectives": [
      {
        "id": "generate_clock",
        "capability": "clock_generation",
        "bindings": [
          {
            "role": "output",
            "port": "clock"
          },
          {
            "role": "power",
            "port": "power"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "output_frequency",
            "relation": "target",
            "value": 8000000,
            "unit": "Hz",
            "tolerance_percent": 0.01
          },
          {
            "name": "clock_fanout",
            "relation": "minimum",
            "value": 2
          },
          {
            "name": "maximum_rms_jitter",
            "relation": "maximum",
            "value": 0.000000001,
            "unit": "s"
          }
        ]
      }
    ],
    "operating_cases": [
      {
        "id": "rated",
        "conditions": [
          {
            "axis": "supply_voltage",
            "target": "logic_3v3",
            "min": 3.15,
            "max": 3.45,
            "unit": "V"
          },
          {
            "axis": "load_capacitance",
            "target": "clock",
            "min": 0.000000000005,
            "max": 0.00000000002,
            "unit": "F"
          },
          {
            "axis": "ambient_temperature",
            "target": "circuit",
            "min": -20,
            "max": 70,
            "unit": "degC"
          }
        ]
      }
    ],
    "behavioral_requirements": [
      {
        "id": "logic_high",
        "metric": "output_high_voltage",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "clock"
        },
        "min": 2.6,
        "unit": "V",
        "operating_cases": [
          "rated"
        ],
        "critical": true
      },
      {
        "id": "rise",
        "metric": "rise_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "clock"
        },
        "max": 0.00000001,
        "unit": "s",
        "operating_cases": [
          "rated"
        ]
      },
      {
        "id": "fall",
        "metric": "fall_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "clock"
        },
        "max": 0.00000001,
        "unit": "s",
        "operating_cases": [
          "rated"
        ]
      },
      {
        "id": "startup",
        "metric": "startup_output_voltage",
        "analysis": "startup",
        "observation": {
          "kind": "port",
          "id": "clock"
        },
        "max": 3.45,
        "unit": "V",
        "operating_cases": [
          "rated"
        ],
        "critical": true
      }
    ],
    "constraints": {
      "max_components": 10,
      "max_width_mm": 38,
      "max_height_mm": 28
    }
  },
  "acceptance": {
    "require_erc": true,
    "require_strict_drc": true,
    "require_complete_routing": true,
    "require_connectivity": true,
    "require_writer_correctness": true,
    "require_round_trip_zero_diff": true,
    "require_deterministic_replay": true,
    "require_contract_composition": true,
    "require_global_reasoning": true,
    "require_coverage_accounting": true,
    "require_alternatives": true,
    "require_fail_closed": true,
    "require_simulation": true,
    "require_all_corners": true,
    "require_model_provenance": true,
    "require_closed_loop_evidence": true
  }
}
