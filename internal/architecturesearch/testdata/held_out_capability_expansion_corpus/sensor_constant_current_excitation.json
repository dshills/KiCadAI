{
  "schema": "kicadai.open-set-requirement.v3",
  "version": 3,
  "project": {
    "name": "sensor_constant_current_excitation",
    "title": "Constant-current sensor excitation",
    "description": "Excite an external resistive sensor with a bounded current over supply, load, temperature, and tolerance corners."
  },
  "requirements": {
    "domains": [
      {
        "id": "analog_9v",
        "kind": "supply",
        "min_voltage_v": 8.1,
        "nominal_voltage_v": 9,
        "max_voltage_v": 9.9,
        "max_current_a": 0.1,
        "source": "external"
      },
      {
        "id": "ground",
        "kind": "reference",
        "nominal_voltage_v": 0,
        "source": "external"
      }
    ],
    "ports": [
      {
        "id": "ground",
        "kind": "reference",
        "direction": "bidirectional",
        "domain": "ground"
      },
      {
        "id": "power",
        "kind": "power",
        "direction": "sink",
        "domain": "analog_9v",
        "electrical": {
          "max_current_a": 0.1
        }
      },
      {
        "id": "sensor_excitation",
        "kind": "analog_voltage",
        "direction": "source",
        "domain": "ground",
        "electrical": {
          "min_voltage_v": 0.5,
          "max_voltage_v": 5,
          "max_source_current_ma": 5
        }
      }
    ],
    "objectives": [
      {
        "id": "excite_sensor",
        "capability": "constant_current_regulation",
        "bindings": [
          {
            "role": "input",
            "port": "power"
          },
          {
            "role": "output",
            "port": "sensor_excitation"
          },
          {
            "role": "reference",
            "port": "ground"
          }
        ],
        "constraints": [
          {
            "name": "output_current",
            "relation": "target",
            "value": 0.001,
            "unit": "A",
            "tolerance_percent": 1
          },
          {
            "name": "minimum_compliance_voltage",
            "relation": "minimum",
            "value": 5,
            "unit": "V"
          }
        ]
      }
    ],
    "operating_cases": [
      {
        "id": "sensor_range",
        "conditions": [
          {
            "axis": "supply_voltage",
            "target": "analog_9v",
            "min": 8.1,
            "max": 9.9,
            "unit": "V"
          },
          {
            "axis": "load_resistance",
            "target": "sensor_excitation",
            "min": 500,
            "max": 5000,
            "unit": "Ohm"
          },
          {
            "axis": "ambient_temperature",
            "target": "circuit",
            "min": -20,
            "max": 70,
            "unit": "degC"
          },
          {
            "axis": "tolerance",
            "target": "circuit",
            "selection": "all"
          }
        ]
      }
    ],
    "behavioral_requirements": [
      {
        "id": "excitation_current",
        "metric": "dc_current",
        "analysis": "dc_operating_point",
        "observation": {
          "kind": "port",
          "id": "sensor_excitation"
        },
        "min": 0.00099,
        "max": 0.00101,
        "unit": "A",
        "operating_cases": [
          "sensor_range"
        ],
        "critical": true
      },
      {
        "id": "response",
        "metric": "response_time",
        "analysis": "transient",
        "observation": {
          "kind": "port",
          "id": "sensor_excitation"
        },
        "max": 0.001,
        "unit": "s",
        "operating_cases": [
          "sensor_range"
        ]
      },
      {
        "id": "startup",
        "metric": "startup_output_voltage",
        "analysis": "startup",
        "observation": {
          "kind": "port",
          "id": "sensor_excitation"
        },
        "max": 0.5,
        "unit": "V",
        "operating_cases": [
          "sensor_range"
        ],
        "critical": true
      },
      {
        "id": "thermal",
        "metric": "junction_temperature",
        "analysis": "thermal",
        "observation": {
          "kind": "port",
          "id": "sensor_excitation"
        },
        "max": 105,
        "unit": "degC",
        "operating_cases": [
          "sensor_range"
        ],
        "critical": true
      }
    ],
    "constraints": {
      "max_components": 14,
      "max_width_mm": 44,
      "max_height_mm": 32
    }
  },
  "acceptance": {
    "require_erc": true,
    "require_strict_drc": true,
    "require_complete_routing": true,
    "require_connectivity": true,
    "require_writer_correctness": true,
    "require_round_trip_zero_diff": true,
    "require_deterministic_replay": true,
    "require_contract_composition": true,
    "require_global_reasoning": true,
    "require_coverage_accounting": true,
    "require_alternatives": true,
    "require_fail_closed": true,
    "require_simulation": true,
    "require_all_corners": true,
    "require_model_provenance": true,
    "require_closed_loop_evidence": true
  }
}
