{
  "version": "0.1.0",
  "name": "generated_multiblock_drc_regression",
  "intent": {
    "summary": "Generated multi-block retry fixture for DRC regression ranking."
  },
  "board": {
    "width_mm": 95,
    "height_mm": 70,
    "layers": 2,
    "edge_clearance_mm": 1
  },
  "blocks": [
    {"id": "status", "block_id": "led_indicator"},
    {
      "id": "header",
      "block_id": "connector_breakout",
      "params": {
        "pin_names": ["VCC", "GND"]
      }
    }
  ],
  "connections": [
    {"from": "status.VCC", "to": "header.VCC", "net_alias": "VCC"},
    {"from": "status.GND", "to": "header.GND", "net_alias": "GND"}
  ],
  "validation": {
    "acceptance": "structural"
  },
  "routing_retry": {
    "enabled": true,
    "max_attempts": 3,
    "allowed_hint_categories": ["increase_spacing", "improve_fanout"],
    "drc_policy": "optional",
    "stop_on_new_blockers": true
  }
}
