{
  "schema": "kicadai.open-set-requirement.v2",
  "version": 2,
  "project": {"name": "protected_sensor_controller", "title": "Protected translated sensor controller", "description": "Regulate a controller rail and connect it to a separately powered sensor bus with translation and supply transient protection."},
  "requirements": {
    "domains": [
      {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"},
      {"id": "input_5v", "kind": "supply", "min_voltage_v": 4.75, "nominal_voltage_v": 5, "max_voltage_v": 5.25, "max_current_a": 0.8, "source": "external"},
      {"id": "logic_3v3", "kind": "supply", "min_voltage_v": 3.15, "nominal_voltage_v": 3.3, "max_voltage_v": 3.45, "max_current_a": 0.3, "source": "logic_rail"},
      {"id": "raw_sensor_1v8", "kind": "supply", "min_voltage_v": 1.7, "nominal_voltage_v": 1.8, "max_voltage_v": 1.9, "max_current_a": 0.08, "source": "external"},
      {"id": "sensor_1v8", "kind": "supply", "min_voltage_v": 1.7, "nominal_voltage_v": 1.8, "max_voltage_v": 1.9, "max_current_a": 0.06, "source": "protected_sensor_rail"}
    ],
    "ports": [
      {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"},
      {"id": "input_power", "kind": "power", "direction": "sink", "domain": "input_5v", "electrical": {"max_current_a": 0.8}},
      {"id": "sensor_power", "kind": "power", "direction": "sink", "domain": "raw_sensor_1v8", "electrical": {"max_current_a": 0.08}}
    ],
    "signals": [
      {"id": "logic_rail", "kind": "power", "domain": "logic_3v3", "electrical": {"min_voltage_v": 3.15, "max_voltage_v": 3.45, "max_current_a": 0.3}},
      {"id": "protected_sensor_rail", "kind": "power", "domain": "sensor_1v8", "electrical": {"min_voltage_v": 1.7, "max_voltage_v": 1.9, "max_current_a": 0.06}}
    ],
    "participants": [
      {"id": "controller", "capability": "programmable_controller", "domain": "logic_3v3", "required_ports": [{"id": "sensor_bus", "kind": "digital_bus", "direction": "bidirectional", "protocol": {"name": "i2c", "mode": "open_drain", "max_frequency_hz": 400000}}], "constraints": [{"name": "programmable_interface", "relation": "required", "value": true}]},
      {"id": "sensor", "capability": "environment_sensor", "domain": "sensor_1v8", "required_ports": [{"id": "controller_bus", "kind": "digital_bus", "direction": "bidirectional", "protocol": {"name": "i2c", "mode": "open_drain", "max_frequency_hz": 400000}}], "constraints": [{"name": "measurement", "relation": "one_of", "value": ["temperature", "humidity"]}]}
    ],
    "objectives": [
      {"id": "protect_sensor_supply", "capability": "transient_protection", "bindings": [{"role": "input", "port": "sensor_power"}, {"role": "output", "signal": "protected_sensor_rail", "direction": "source"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "reverse_current_blocking", "relation": "required", "value": true}]},
      {"id": "regulate_logic", "capability": "voltage_regulation", "bindings": [{"role": "input", "port": "input_power"}, {"role": "output", "signal": "logic_rail", "direction": "source"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "output_voltage", "relation": "target", "value": 3.3, "unit": "V", "tolerance_percent": 3}]},
      {"id": "translate_sensor_bus", "capability": "logic_level_translation", "bindings": [{"role": "side_a", "participant": "controller", "participant_port": "sensor_bus"}, {"role": "side_b", "participant": "sensor", "participant_port": "controller_bus"}, {"role": "power_a", "signal": "logic_rail", "direction": "sink"}, {"role": "power_b", "signal": "protected_sensor_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "protocol", "relation": "equal", "value": "i2c"}, {"name": "unpowered_backfeed_prevention", "relation": "required", "value": true}]}
    ],
    "system_constraints": [{"name": "startup_bus_state", "relation": "equal", "value": "released"}, {"name": "supply_current_headroom", "relation": "minimum", "value": 20, "unit": "%"}],
    "constraints": {"max_components": 32, "max_width_mm": 70, "max_height_mm": 50}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
