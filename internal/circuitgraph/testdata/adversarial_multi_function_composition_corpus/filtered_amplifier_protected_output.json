{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "filtered_amplifier_protected_output", "title": "Filtered amplifier with protected output", "description": "Low-pass an analog input, amplify it, and protect the externally driven output against overload and transients."},
  "requirements": {
    "domains": [{"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "analog_12v", "kind": "supply", "min_voltage_v": 10.8, "nominal_voltage_v": 12, "max_voltage_v": 13.2, "max_current_a": 0.4, "source": "external"}],
    "ports": [{"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "power", "kind": "power", "direction": "sink", "domain": "analog_12v", "electrical": {"max_current_a": 0.4}}, {"id": "signal_input", "kind": "analog_voltage", "direction": "sink", "domain": "ground", "electrical": {"min_voltage_v": -1, "max_voltage_v": 1, "input_impedance_min_ohm": 47000, "frequency_max_hz": 50000}}, {"id": "protected_output", "kind": "protected_output", "direction": "source", "domain": "ground", "electrical": {"min_voltage_v": -6, "max_voltage_v": 6, "max_source_current_ma": 50, "frequency_max_hz": 20000}}],
    "signals": [{"id": "amplified_signal", "kind": "analog_voltage", "domain": "ground", "electrical": {"min_voltage_v": -6, "max_voltage_v": 6, "max_source_current_ma": 60, "frequency_max_hz": 20000}}, {"id": "filtered_signal", "kind": "analog_voltage", "domain": "ground", "electrical": {"min_voltage_v": -1, "max_voltage_v": 1, "input_impedance_min_ohm": 100000, "frequency_max_hz": 20000}}],
    "objectives": [
      {"id": "amplify", "capability": "signal_amplification", "bindings": [{"role": "input", "signal": "filtered_signal", "direction": "sink"}, {"role": "output", "signal": "amplified_signal", "direction": "source"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "voltage_gain", "relation": "target", "value": 6, "tolerance_percent": 3}, {"name": "output_current", "relation": "minimum", "value": 0.06, "unit": "A"}]},
      {"id": "filter", "capability": "frequency_filter", "bindings": [{"role": "input", "port": "signal_input"}, {"role": "output", "signal": "filtered_signal", "direction": "source"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "response", "relation": "equal", "value": "low_pass"}, {"name": "cutoff_frequency", "relation": "target", "value": 18000, "unit": "Hz", "tolerance_percent": 5}, {"name": "order", "relation": "minimum", "value": 2}]},
      {"id": "protect_output", "capability": "output_protection", "bindings": [{"role": "input", "signal": "amplified_signal", "direction": "sink"}, {"role": "output", "port": "protected_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "overcurrent_limit", "relation": "maximum", "value": 0.05, "unit": "A"}, {"name": "transient_clamp", "relation": "required", "value": true}]}
    ],
    "system_constraints": [{"name": "phase_margin", "relation": "minimum", "value": 45, "unit": "deg"}, {"name": "startup_output_state", "relation": "equal", "value": "inactive"}],
    "constraints": {"max_components": 34, "max_width_mm": 75, "max_height_mm": 50}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
