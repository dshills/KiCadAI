{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "precision_sensor_decision_chain", "title": "Precision sensor decision chain", "description": "Amplify a low-level sensor signal, reject out-of-band noise, detect a precision threshold, and expose the decision state."},
  "requirements": {
    "domains": [{"id": "analog_5v", "kind": "supply", "min_voltage_v": 4.75, "nominal_voltage_v": 5, "max_voltage_v": 5.25, "max_current_a": 0.2, "source": "external"}, {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}],
    "ports": [{"id": "decision_output", "kind": "digital_logic", "direction": "source", "domain": "analog_5v", "electrical": {"max_source_current_ma": 4, "default_state": "inactive"}}, {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "power", "kind": "power", "direction": "sink", "domain": "analog_5v", "electrical": {"max_current_a": 0.2}}, {"id": "sensor_input", "kind": "differential_analog", "direction": "sink", "domain": "ground", "electrical": {"min_voltage_v": -0.02, "max_voltage_v": 0.02, "input_impedance_min_ohm": 1000000, "frequency_max_hz": 1000}}],
    "signals": [{"id": "amplified_signal", "kind": "analog_voltage", "domain": "analog_5v", "electrical": {"min_voltage_v": 0, "max_voltage_v": 4, "input_impedance_min_ohm": 100000, "frequency_max_hz": 1000}}, {"id": "filtered_signal", "kind": "analog_voltage", "domain": "analog_5v", "electrical": {"min_voltage_v": 0, "max_voltage_v": 4, "input_impedance_min_ohm": 100000, "frequency_max_hz": 100}}, {"id": "threshold_state", "kind": "digital_logic", "domain": "analog_5v", "electrical": {"min_voltage_v": 0, "max_voltage_v": 5, "default_state": "inactive"}}],
    "objectives": [
      {"id": "amplify_sensor", "capability": "instrumentation_amplification", "bindings": [{"role": "input", "port": "sensor_input"}, {"role": "output", "signal": "amplified_signal", "direction": "source"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "voltage_gain", "relation": "target", "value": 100, "tolerance_percent": 1}, {"name": "common_mode_rejection", "relation": "minimum", "value": 80, "unit": "dB"}]},
      {"id": "detect_threshold", "capability": "threshold_detection", "bindings": [{"role": "input", "signal": "filtered_signal", "direction": "sink"}, {"role": "output", "signal": "threshold_state", "direction": "source"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "rising_threshold", "relation": "target", "value": 2.5, "unit": "V", "tolerance_percent": 1}, {"name": "hysteresis", "relation": "minimum", "value": 0.05, "unit": "V"}]},
      {"id": "filter_sensor", "capability": "frequency_filter", "bindings": [{"role": "input", "signal": "amplified_signal", "direction": "sink"}, {"role": "output", "signal": "filtered_signal", "direction": "source"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "response", "relation": "equal", "value": "low_pass"}, {"name": "cutoff_frequency", "relation": "target", "value": 100, "unit": "Hz", "tolerance_percent": 3}]},
      {"id": "indicate_decision", "capability": "fault_indication", "bindings": [{"role": "state", "signal": "threshold_state", "direction": "sink"}, {"role": "output", "port": "decision_output"}, {"role": "power", "port": "power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "active_state", "relation": "equal", "value": "high"}]}
    ],
    "system_constraints": [{"name": "input_referred_noise", "relation": "maximum", "value": 20, "unit": "uV_rms"}, {"name": "phase_margin", "relation": "minimum", "value": 45, "unit": "deg"}],
    "constraints": {"max_components": 38, "max_width_mm": 80, "max_height_mm": 55}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
