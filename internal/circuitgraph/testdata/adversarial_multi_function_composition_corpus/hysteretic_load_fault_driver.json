{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "hysteretic_load_fault_driver", "title": "Hysteretic protected load driver", "description": "Use a hysteretic threshold decision to control a protected inductive load and expose a fault indication."},
  "requirements": {
    "domains": [{"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "logic_3v3", "kind": "supply", "min_voltage_v": 3.1, "nominal_voltage_v": 3.3, "max_voltage_v": 3.5, "max_current_a": 0.1, "source": "external"}, {"id": "load_12v", "kind": "supply", "min_voltage_v": 10.8, "nominal_voltage_v": 12, "max_voltage_v": 13.2, "max_current_a": 2, "source": "external"}],
    "ports": [{"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "logic_power", "kind": "power", "direction": "sink", "domain": "logic_3v3", "electrical": {"max_current_a": 0.1}}, {"id": "load_power", "kind": "power", "direction": "sink", "domain": "load_12v", "electrical": {"max_current_a": 2}}, {"id": "sense_input", "kind": "analog_voltage", "direction": "sink", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 3.3, "input_impedance_min_ohm": 100000}}, {"id": "load_output", "kind": "switched_load", "direction": "source", "domain": "load_12v", "electrical": {"max_current_a": 1.5}}, {"id": "fault_output", "kind": "digital_logic", "direction": "source", "domain": "logic_3v3", "electrical": {"max_source_current_ma": 4, "default_state": "inactive"}}],
    "signals": [{"id": "switch_command", "kind": "digital_logic", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 3.3, "default_state": "inactive"}}],
    "objectives": [
      {"id": "drive_load", "capability": "load_switch", "bindings": [{"role": "control", "signal": "switch_command", "direction": "sink"}, {"role": "power", "port": "load_power"}, {"role": "output", "port": "load_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "load_current", "relation": "minimum", "value": 1.5, "unit": "A"}, {"name": "inductive_clamp", "relation": "required", "value": true}, {"name": "startup_state", "relation": "equal", "value": "off"}]},
      {"id": "indicate_fault", "capability": "fault_indication", "bindings": [{"role": "state", "signal": "switch_command", "direction": "sink"}, {"role": "power", "port": "logic_power"}, {"role": "output", "port": "fault_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "active_state", "relation": "equal", "value": "high"}]},
      {"id": "sense_threshold", "capability": "threshold_detection", "bindings": [{"role": "input", "port": "sense_input"}, {"role": "output", "signal": "switch_command", "direction": "source"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "rising_threshold", "relation": "target", "value": 2.1, "unit": "V", "tolerance_percent": 3}, {"name": "hysteresis", "relation": "minimum", "value": 0.18, "unit": "V"}]}
    ],
    "system_constraints": [{"name": "startup_load_state", "relation": "equal", "value": "off"}, {"name": "supply_current_headroom", "relation": "minimum", "value": 25, "unit": "%"}],
    "constraints": {"max_components": 28, "max_width_mm": 65, "max_height_mm": 45}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
