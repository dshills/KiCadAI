{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "current_sensed_load_protection", "title": "Current-sensed protected load", "description": "Measure load current, disconnect the controlled output on an overcurrent decision, and expose the fault state."},
  "requirements": {
    "domains": [{"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "logic_3v3", "kind": "supply", "min_voltage_v": 3.1, "nominal_voltage_v": 3.3, "max_voltage_v": 3.5, "max_current_a": 0.12, "source": "external"}, {"id": "load_24v", "kind": "supply", "min_voltage_v": 21.6, "nominal_voltage_v": 24, "max_voltage_v": 26.4, "max_current_a": 3, "source": "external"}],
    "ports": [{"id": "control_input", "kind": "digital_logic", "direction": "sink", "domain": "logic_3v3", "electrical": {"default_state": "inactive"}}, {"id": "fault_output", "kind": "digital_logic", "direction": "source", "domain": "logic_3v3", "electrical": {"max_source_current_ma": 4, "default_state": "inactive"}}, {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "load_output", "kind": "switched_load", "direction": "source", "domain": "load_24v", "electrical": {"max_current_a": 2}}, {"id": "load_power", "kind": "power", "direction": "sink", "domain": "load_24v", "electrical": {"max_current_a": 3}}, {"id": "logic_power", "kind": "power", "direction": "sink", "domain": "logic_3v3", "electrical": {"max_current_a": 0.12}}],
    "signals": [{"id": "fault_state", "kind": "digital_logic", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 3.3, "default_state": "inactive"}}, {"id": "measured_current", "kind": "analog_voltage", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 2.5, "input_impedance_min_ohm": 100000, "frequency_max_hz": 10000}}, {"id": "protected_control", "kind": "digital_logic", "domain": "logic_3v3", "electrical": {"default_state": "inactive"}}],
    "objectives": [
      {"id": "decide_overcurrent", "capability": "threshold_detection", "bindings": [{"role": "input", "signal": "measured_current", "direction": "sink"}, {"role": "output", "signal": "fault_state", "direction": "source"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "rising_threshold", "relation": "target", "value": 2, "unit": "V", "tolerance_percent": 2}, {"name": "hysteresis", "relation": "minimum", "value": 0.1, "unit": "V"}]},
      {"id": "drive_load", "capability": "load_switch", "bindings": [{"role": "control", "signal": "protected_control", "direction": "sink"}, {"role": "power", "port": "load_power"}, {"role": "output", "port": "load_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "load_current", "relation": "minimum", "value": 2, "unit": "A"}, {"name": "overcurrent_shutdown", "relation": "required", "value": true}, {"name": "startup_state", "relation": "equal", "value": "off"}]},
      {"id": "indicate_fault", "capability": "fault_indication", "bindings": [{"role": "state", "signal": "fault_state", "direction": "sink"}, {"role": "output", "port": "fault_output"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "active_state", "relation": "equal", "value": "high"}]},
      {"id": "sense_and_interlock", "capability": "current_sensing", "bindings": [{"role": "control", "port": "control_input"}, {"role": "fault", "signal": "fault_state", "direction": "sink"}, {"role": "measurement", "signal": "measured_current", "direction": "source"}, {"role": "permit", "signal": "protected_control", "direction": "source"}, {"role": "power", "port": "load_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "full_scale_current", "relation": "target", "value": 2, "unit": "A", "tolerance_percent": 2}, {"name": "fail_safe_interlock", "relation": "required", "value": true}]}
    ],
    "system_constraints": [{"name": "startup_load_state", "relation": "equal", "value": "off"}, {"name": "fault_response_time", "relation": "maximum", "value": 100, "unit": "us"}, {"name": "supply_current_headroom", "relation": "minimum", "value": 20, "unit": "%"}],
    "constraints": {"max_components": 36, "max_width_mm": 80, "max_height_mm": 55}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
