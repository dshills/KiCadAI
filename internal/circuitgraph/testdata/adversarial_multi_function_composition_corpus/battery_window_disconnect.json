{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "battery_window_disconnect", "title": "Battery-window load disconnect", "description": "Disconnect a battery load unless two threshold decisions prove that the supply remains inside its permitted operating window."},
  "requirements": {
    "domains": [{"id": "battery", "kind": "supply", "min_voltage_v": 9, "nominal_voltage_v": 12, "max_voltage_v": 15, "max_current_a": 3, "source": "external"}, {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}],
    "ports": [{"id": "battery_input", "kind": "power", "direction": "sink", "domain": "battery", "electrical": {"max_current_a": 3}}, {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "load_output", "kind": "switched_load", "direction": "source", "domain": "battery", "electrical": {"max_current_a": 2.5}}, {"id": "sense_input", "kind": "analog_voltage", "direction": "sink", "domain": "battery", "electrical": {"min_voltage_v": 9, "max_voltage_v": 15, "input_impedance_min_ohm": 200000}}],
    "signals": [{"id": "over_limit", "kind": "digital_logic", "domain": "battery", "electrical": {"default_state": "active"}}, {"id": "permit_load", "kind": "digital_logic", "domain": "battery", "electrical": {"default_state": "inactive"}}, {"id": "under_limit", "kind": "digital_logic", "domain": "battery", "electrical": {"default_state": "active"}}],
    "objectives": [
      {"id": "combine_window", "capability": "safety_interlock", "bindings": [{"role": "fault_a", "signal": "under_limit", "direction": "sink"}, {"role": "fault_b", "signal": "over_limit", "direction": "sink"}, {"role": "permit", "signal": "permit_load", "direction": "source"}, {"role": "power", "port": "battery_input"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "logic", "relation": "equal", "value": "inside_window_only"}, {"name": "startup_state", "relation": "equal", "value": "blocked"}]},
      {"id": "disconnect_load", "capability": "load_switch", "bindings": [{"role": "control", "signal": "permit_load", "direction": "sink"}, {"role": "power", "port": "battery_input"}, {"role": "output", "port": "load_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "load_current", "relation": "minimum", "value": 2.5, "unit": "A"}, {"name": "startup_state", "relation": "equal", "value": "off"}]},
      {"id": "detect_overvoltage", "capability": "threshold_detection", "bindings": [{"role": "input", "port": "sense_input"}, {"role": "output", "signal": "over_limit", "direction": "source"}, {"role": "power", "port": "battery_input"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "rising_threshold", "relation": "target", "value": 14.4, "unit": "V", "tolerance_percent": 2}, {"name": "polarity", "relation": "equal", "value": "fault_above"}]},
      {"id": "detect_undervoltage", "capability": "threshold_detection", "bindings": [{"role": "input", "port": "sense_input"}, {"role": "output", "signal": "under_limit", "direction": "source"}, {"role": "power", "port": "battery_input"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "falling_threshold", "relation": "target", "value": 10.2, "unit": "V", "tolerance_percent": 2}, {"name": "polarity", "relation": "equal", "value": "fault_below"}]}
    ],
    "system_constraints": [{"name": "startup_load_state", "relation": "equal", "value": "off"}, {"name": "supply_current_headroom", "relation": "minimum", "value": 15, "unit": "%"}],
    "constraints": {"max_components": 32, "max_width_mm": 75, "max_height_mm": 50}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
