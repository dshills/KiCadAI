{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "regulated_class_a_line_driver", "title": "Regulated Class-A line driver", "description": "Regulate an analog rail, bias a Class-A voltage amplifier, and protect a low-impedance line output."},
  "requirements": {
    "domains": [{"id": "analog_15v", "kind": "supply", "min_voltage_v": 14.7, "nominal_voltage_v": 15, "max_voltage_v": 15.3, "max_current_a": 0.25, "source": "regulated_rail"}, {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "input_18v", "kind": "supply", "min_voltage_v": 18, "nominal_voltage_v": 18, "max_voltage_v": 19.8, "max_current_a": 0.5, "source": "external"}],
    "ports": [{"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "input_power", "kind": "power", "direction": "sink", "domain": "input_18v", "electrical": {"max_current_a": 0.5}}, {"id": "line_input", "kind": "analog_voltage", "direction": "sink", "domain": "ground", "electrical": {"min_voltage_v": -0.5, "max_voltage_v": 0.5, "input_impedance_min_ohm": 47000, "frequency_max_hz": 100000}}, {"id": "line_output", "kind": "protected_output", "direction": "source", "domain": "ground", "electrical": {"min_voltage_v": -4, "max_voltage_v": 4, "max_source_current_ma": 40, "frequency_max_hz": 100000}}],
    "signals": [{"id": "amplified_signal", "kind": "analog_voltage", "domain": "ground", "electrical": {"min_voltage_v": -4, "max_voltage_v": 4, "max_source_current_ma": 50, "frequency_max_hz": 100000}}, {"id": "regulated_rail", "kind": "power", "domain": "analog_15v", "electrical": {"min_voltage_v": 14.7, "max_voltage_v": 15.3, "max_current_a": 0.25}}],
    "objectives": [
      {"id": "amplify_class_a", "capability": "class_a_amplification", "bindings": [{"role": "input", "port": "line_input"}, {"role": "output", "signal": "amplified_signal", "direction": "source"}, {"role": "power", "signal": "regulated_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "voltage_gain", "relation": "target", "value": 8, "tolerance_percent": 3}, {"name": "quiescent_current", "relation": "target", "value": 0.06, "unit": "A", "tolerance_percent": 10}]},
      {"id": "protect_line", "capability": "output_protection", "bindings": [{"role": "input", "signal": "amplified_signal", "direction": "sink"}, {"role": "output", "port": "line_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "overcurrent_limit", "relation": "maximum", "value": 0.04, "unit": "A"}, {"name": "capacitive_load_stability", "relation": "minimum", "value": 1000, "unit": "pF"}]},
      {"id": "regulate_analog_rail", "capability": "voltage_regulation", "bindings": [{"role": "input", "port": "input_power"}, {"role": "output", "signal": "regulated_rail", "direction": "source"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "output_voltage", "relation": "target", "value": 15, "unit": "V", "tolerance_percent": 2}, {"name": "output_current", "relation": "minimum", "value": 0.25, "unit": "A"}]}
    ],
    "system_constraints": [{"name": "thermal_margin", "relation": "minimum", "value": 20, "unit": "degC"}, {"name": "phase_margin", "relation": "minimum", "value": 45, "unit": "deg"}, {"name": "supply_current_headroom", "relation": "minimum", "value": 20, "unit": "%"}],
    "constraints": {"max_components": 34, "max_width_mm": 80, "max_height_mm": 55}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
