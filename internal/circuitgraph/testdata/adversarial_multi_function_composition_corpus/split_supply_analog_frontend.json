{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "split_supply_analog_frontend", "title": "Split-supply filtered analog front end", "description": "Generate adjustable positive and negative analog rails, filter an input, and amplify it across the split supply."},
  "requirements": {
    "domains": [{"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "input_15v", "kind": "supply", "min_voltage_v": 13.5, "nominal_voltage_v": 15, "max_voltage_v": 16.5, "max_current_a": 0.5, "source": "external"}, {"id": "analog_positive", "kind": "supply", "min_voltage_v": 8.8, "nominal_voltage_v": 9, "max_voltage_v": 9.2, "max_current_a": 0.12, "source": "positive_rail"}, {"id": "analog_negative", "kind": "supply", "min_voltage_v": -9.2, "nominal_voltage_v": -9, "max_voltage_v": -8.8, "max_current_a": 0.12, "source": "negative_rail"}],
    "ports": [{"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "input_power", "kind": "power", "direction": "sink", "domain": "input_15v", "electrical": {"max_current_a": 0.5}}, {"id": "analog_input", "kind": "analog_voltage", "direction": "sink", "domain": "ground", "electrical": {"min_voltage_v": -0.5, "max_voltage_v": 0.5, "input_impedance_min_ohm": 100000, "frequency_max_hz": 20000}}, {"id": "analog_output", "kind": "analog_voltage", "direction": "source", "domain": "ground", "electrical": {"min_voltage_v": -5, "max_voltage_v": 5, "max_source_current_ma": 10, "frequency_max_hz": 20000}}],
    "signals": [{"id": "filtered_signal", "kind": "analog_voltage", "domain": "ground", "electrical": {"min_voltage_v": -0.5, "max_voltage_v": 0.5, "input_impedance_min_ohm": 100000, "frequency_max_hz": 20000}}, {"id": "negative_rail", "kind": "power", "domain": "analog_negative", "electrical": {"min_voltage_v": -9.2, "max_voltage_v": -8.8, "max_current_a": 0.12}}, {"id": "positive_rail", "kind": "power", "domain": "analog_positive", "electrical": {"min_voltage_v": 8.8, "max_voltage_v": 9.2, "max_current_a": 0.12}}],
    "objectives": [
      {"id": "amplify_signal", "capability": "signal_amplification", "bindings": [{"role": "input", "signal": "filtered_signal", "direction": "sink"}, {"role": "output", "port": "analog_output"}, {"role": "positive_power", "signal": "positive_rail", "direction": "sink"}, {"role": "negative_power", "signal": "negative_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "voltage_gain", "relation": "target", "value": 10, "tolerance_percent": 2}, {"name": "gain_bandwidth_margin", "relation": "minimum", "value": 10}]},
      {"id": "filter_input", "capability": "frequency_filter", "bindings": [{"role": "input", "port": "analog_input"}, {"role": "output", "signal": "filtered_signal", "direction": "source"}, {"role": "positive_power", "signal": "positive_rail", "direction": "sink"}, {"role": "negative_power", "signal": "negative_rail", "direction": "sink"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "response", "relation": "equal", "value": "low_pass"}, {"name": "cutoff_frequency", "relation": "target", "value": 20000, "unit": "Hz", "tolerance_percent": 5}]},
      {"id": "generate_split_supply", "capability": "split_supply_generation", "bindings": [{"role": "input", "port": "input_power"}, {"role": "positive_output", "signal": "positive_rail", "direction": "source"}, {"role": "negative_output", "signal": "negative_rail", "direction": "source"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "positive_voltage", "relation": "target", "value": 9, "unit": "V", "tolerance_percent": 2}, {"name": "negative_voltage", "relation": "target", "value": -9, "unit": "V", "tolerance_percent": 2}]}
    ],
    "system_constraints": [{"name": "rail_current_headroom", "relation": "minimum", "value": 20, "unit": "%"}, {"name": "phase_margin", "relation": "minimum", "value": 45, "unit": "deg"}],
    "constraints": {"max_components": 36, "max_width_mm": 80, "max_height_mm": 55}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
