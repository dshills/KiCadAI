{
  "schema": "kicadai.open-set-requirement.v2", "version": 2,
  "project": {"name": "mcu_managed_class_ab_output", "title": "MCU-managed Class-AB output stage", "description": "Use a programmable controller to manage Class-AB bias and mute behavior while protecting the amplified load output."},
  "requirements": {
    "domains": [{"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"}, {"id": "logic_3v3", "kind": "supply", "min_voltage_v": 3.1, "nominal_voltage_v": 3.3, "max_voltage_v": 3.5, "max_current_a": 0.25, "source": "external"}, {"id": "output_24v", "kind": "supply", "min_voltage_v": 21.6, "nominal_voltage_v": 24, "max_voltage_v": 26.4, "max_current_a": 2.5, "source": "external"}],
    "ports": [{"id": "audio_input", "kind": "analog_voltage", "direction": "sink", "domain": "ground", "electrical": {"min_voltage_v": -1, "max_voltage_v": 1, "input_impedance_min_ohm": 22000, "frequency_max_hz": 20000}}, {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}, {"id": "logic_power", "kind": "power", "direction": "sink", "domain": "logic_3v3", "electrical": {"max_current_a": 0.25}}, {"id": "load_output", "kind": "protected_output", "direction": "source", "domain": "ground", "electrical": {"min_voltage_v": -10, "max_voltage_v": 10, "max_current_a": 1.5, "frequency_max_hz": 20000}}, {"id": "output_power", "kind": "power", "direction": "sink", "domain": "output_24v", "electrical": {"max_current_a": 2.5}}],
    "signals": [{"id": "amplified_output", "kind": "analog_voltage", "domain": "ground", "electrical": {"min_voltage_v": -10, "max_voltage_v": 10, "max_current_a": 1.8, "frequency_max_hz": 20000}}, {"id": "bias_drive", "kind": "analog_control", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0.9, "max_voltage_v": 1.5, "default_state": "inactive"}}, {"id": "mute_state", "kind": "digital_logic", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 3.3, "default_state": "active"}}],
    "participants": [{"id": "controller", "capability": "programmable_controller", "domain": "logic_3v3", "required_ports": [{"id": "bias_enable", "kind": "digital_logic", "direction": "source"}, {"id": "mute_enable", "kind": "digital_logic", "direction": "source"}], "constraints": [{"name": "programmable_interface", "relation": "required", "value": true}]}],
    "objectives": [
      {"id": "control_bias", "capability": "class_ab_bias_control", "bindings": [{"role": "enable", "participant": "controller", "participant_port": "bias_enable"}, {"role": "bias", "signal": "bias_drive", "direction": "source"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "quiescent_current", "relation": "target", "value": 0.08, "unit": "A", "tolerance_percent": 10}, {"name": "thermal_tracking", "relation": "required", "value": true}]},
      {"id": "control_mute", "capability": "mute_control", "bindings": [{"role": "enable", "participant": "controller", "participant_port": "mute_enable"}, {"role": "mute", "signal": "mute_state", "direction": "source"}, {"role": "power", "port": "logic_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "startup_state", "relation": "equal", "value": "muted"}]},
      {"id": "drive_class_ab", "capability": "class_ab_output_stage", "bindings": [{"role": "input", "port": "audio_input"}, {"role": "bias", "signal": "bias_drive", "direction": "sink"}, {"role": "mute", "signal": "mute_state", "direction": "sink"}, {"role": "output", "signal": "amplified_output", "direction": "source"}, {"role": "power", "port": "output_power"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "load_impedance", "relation": "minimum", "value": 8, "unit": "ohm"}, {"name": "continuous_output_power", "relation": "minimum", "value": 8, "unit": "W"}]},
      {"id": "protect_load", "capability": "output_protection", "bindings": [{"role": "input", "signal": "amplified_output", "direction": "sink"}, {"role": "output", "port": "load_output"}, {"role": "reference", "port": "ground"}], "constraints": [{"name": "dc_fault_disconnect", "relation": "required", "value": true}, {"name": "overcurrent_limit", "relation": "maximum", "value": 1.5, "unit": "A"}]}
    ],
    "system_constraints": [{"name": "startup_output_state", "relation": "equal", "value": "muted"}, {"name": "thermal_margin", "relation": "minimum", "value": 20, "unit": "degC"}, {"name": "phase_margin", "relation": "minimum", "value": 45, "unit": "deg"}],
    "constraints": {"max_components": 48, "max_width_mm": 100, "max_height_mm": 70}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true, "require_contract_composition": true, "require_global_reasoning": true, "require_coverage_accounting": true, "require_alternatives": true, "require_fail_closed": true}
}
