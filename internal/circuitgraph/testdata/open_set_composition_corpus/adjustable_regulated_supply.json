{
  "schema": "kicadai.open-set-requirement.v1",
  "version": 1,
  "project": {
    "name": "adjustable_regulated_supply",
    "title": "Adjustable regulated supply",
    "description": "Generate a tolerance-bounded five-volt rail from a varying twelve-volt input using a passively programmed set point."
  },
  "requirements": {
    "domains": [
      {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"},
      {"id": "input_supply", "kind": "supply", "min_voltage_v": 9, "nominal_voltage_v": 12, "max_voltage_v": 15, "max_current_a": 0.5, "source": "external"},
      {"id": "regulated_5v", "kind": "supply", "min_voltage_v": 4.9, "nominal_voltage_v": 5, "max_voltage_v": 5.1, "max_current_a": 0.25, "source": "generated"}
    ],
    "ports": [
      {"id": "input", "kind": "power", "direction": "sink", "domain": "input_supply", "electrical": {"min_voltage_v": 9, "max_voltage_v": 15, "max_current_a": 0.5}},
      {"id": "output", "kind": "power", "direction": "source", "domain": "regulated_5v", "electrical": {"min_voltage_v": 4.9, "nominal_voltage_v": 5, "max_voltage_v": 5.1, "max_current_a": 0.25}},
      {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"}
    ],
    "objectives": [
      {
        "id": "regulate_output",
        "capability": "voltage_regulation",
        "bindings": [
          {"role": "input", "port": "input"},
          {"role": "output", "port": "output"},
          {"role": "reference", "port": "ground"}
        ],
        "constraints": [
          {"name": "output_voltage", "relation": "target", "value": 5, "unit": "V", "tolerance_percent": 2},
          {"name": "continuous_output_current", "relation": "minimum", "value": 0.25, "unit": "A"},
          {"name": "input_voltage", "relation": "range", "value": [9, 15], "unit": "V"},
          {"name": "adjustable_output", "relation": "required", "value": true},
          {"name": "set_point_programming", "relation": "equal", "value": "passive_feedback"},
          {"name": "input_decoupling", "relation": "required", "value": true},
          {"name": "output_decoupling", "relation": "required", "value": true}
        ]
      }
    ],
    "constraints": {"max_components": 14, "max_width_mm": 45, "max_height_mm": 30}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true}
}
