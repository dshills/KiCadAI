{
  "schema": "kicadai.open-set-requirement.v1",
  "version": 1,
  "project": {
    "name": "protected_inductive_load_switch",
    "title": "Protected inductive load switch",
    "description": "Control a grounded inductive load from low-voltage logic with safe startup and transient protection."
  },
  "requirements": {
    "domains": [
      {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"},
      {"id": "load_12v", "kind": "supply", "min_voltage_v": 10.8, "nominal_voltage_v": 12, "max_voltage_v": 13.2, "max_current_a": 2, "source": "external"},
      {"id": "logic_3v3", "kind": "supply", "min_voltage_v": 3, "nominal_voltage_v": 3.3, "max_voltage_v": 3.6, "max_current_a": 0.02, "source": "external"}
    ],
    "ports": [
      {"id": "logic_power", "kind": "power", "direction": "sink", "domain": "logic_3v3", "electrical": {"max_current_a": 0.02}},
      {"id": "load_power", "kind": "power", "direction": "sink", "domain": "load_12v", "electrical": {"max_current_a": 2}},
      {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"},
      {"id": "control", "kind": "digital_logic", "direction": "sink", "domain": "logic_3v3", "electrical": {"min_voltage_v": 0, "max_voltage_v": 3.3, "max_source_current_ma": 4, "default_state": "low"}},
      {"id": "load_return", "kind": "switched_load", "direction": "sink", "domain": "load_12v", "electrical": {"max_voltage_v": 13.2, "max_current_a": 2}}
    ],
    "objectives": [
      {
        "id": "control_load",
        "capability": "load_switch",
        "bindings": [
          {"role": "control", "port": "control"},
          {"role": "load", "port": "load_return"},
          {"role": "load_power", "port": "load_power"},
          {"role": "logic_power", "port": "logic_power"},
          {"role": "reference", "port": "ground"}
        ],
        "constraints": [
          {"name": "load_current", "relation": "minimum", "value": 2, "unit": "A"},
          {"name": "load_voltage", "relation": "minimum", "value": 13.2, "unit": "V"},
          {"name": "load_characteristic", "relation": "equal", "value": "inductive"},
          {"name": "control_active_state", "relation": "equal", "value": "high"},
          {"name": "default_off", "relation": "required", "value": true},
          {"name": "inductive_transient_clamp", "relation": "required", "value": true},
          {"name": "control_overvoltage_clamp", "relation": "required", "value": true}
        ]
      }
    ],
    "constraints": {"max_components": 12, "max_width_mm": 40, "max_height_mm": 30}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true}
}
