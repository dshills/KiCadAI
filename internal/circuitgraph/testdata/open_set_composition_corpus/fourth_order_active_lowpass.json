{
  "schema": "kicadai.open-set-requirement.v1",
  "version": 1,
  "project": {
    "name": "fourth_order_active_lowpass",
    "title": "Fourth-order active low-pass filter",
    "description": "Condition a ground-referenced signal with a bounded fourth-order low-pass response and unity passband gain."
  },
  "requirements": {
    "domains": [
      {"id": "ground", "kind": "reference", "nominal_voltage_v": 0, "source": "external"},
      {"id": "logic_5v", "kind": "supply", "min_voltage_v": 4.75, "nominal_voltage_v": 5, "max_voltage_v": 5.25, "max_current_a": 0.05, "source": "external"}
    ],
    "ports": [
      {"id": "power", "kind": "power", "direction": "sink", "domain": "logic_5v", "electrical": {"max_current_a": 0.05}},
      {"id": "ground", "kind": "reference", "direction": "bidirectional", "domain": "ground"},
      {"id": "signal_in", "kind": "analog_voltage", "direction": "sink", "domain": "logic_5v", "electrical": {"min_voltage_v": 0.5, "max_voltage_v": 4.5, "frequency_max_hz": 50000, "input_impedance_min_ohm": 10000}},
      {"id": "signal_out", "kind": "analog_voltage", "direction": "source", "domain": "logic_5v", "electrical": {"min_voltage_v": 0.5, "max_voltage_v": 4.5, "max_source_current_ma": 2}}
    ],
    "objectives": [
      {
        "id": "shape_frequency_response",
        "capability": "frequency_filter",
        "bindings": [
          {"role": "input", "port": "signal_in"},
          {"role": "output", "port": "signal_out"},
          {"role": "power", "port": "power"},
          {"role": "reference", "port": "ground"}
        ],
        "constraints": [
          {"name": "response", "relation": "equal", "value": "low_pass"},
          {"name": "approximation", "relation": "equal", "value": "butterworth"},
          {"name": "order", "relation": "equal", "value": 4},
          {"name": "cutoff_frequency", "relation": "target", "value": 2000, "unit": "Hz", "tolerance_percent": 5},
          {"name": "passband_gain", "relation": "target", "value": 1, "unit": "ratio", "tolerance_percent": 2},
          {"name": "passband_ripple", "relation": "maximum", "value": 0.5, "unit": "dB"}
        ]
      }
    ],
    "constraints": {"max_components": 28, "max_width_mm": 55, "max_height_mm": 35}
  },
  "acceptance": {"require_erc": true, "require_strict_drc": true, "require_complete_routing": true, "require_connectivity": true, "require_writer_correctness": true, "require_round_trip_zero_diff": true, "require_deterministic_replay": true}
}
